# ─────────────────────────────────────────────────────────────────────────────
#  Конфигурация авто-обновлений (Sparkle). Единый источник правды для
#  build.sh (вшивает в Info.plist) и release.sh (генерирует appcast).
#
#  ▸ Что ОБЯЗАТЕЛЬНО поменять перед первым релизом: SPARKLE_GITHUB_OWNER.
#  ▸ Версию/сборку обычно бампит release.sh сам — руками лезть не нужно.
# ─────────────────────────────────────────────────────────────────────────────

# Видимая версия (CFBundleShortVersionString) — то, что видит пользователь.
APP_VERSION="1.4.10"
# Номер сборки (CFBundleVersion) — ИМЕННО его Sparkle сравнивает, чтобы понять,
# что вышло обновление. Должен строго расти от релиза к релизу. release.sh бампит сам.
APP_BUILD="15"

# Публичный ключ EdDSA (приватный лежит в Keychain + бэкап в ~/). НЕ менять —
# иначе уже установленные у друзей копии перестанут принимать обновления.
SPARKLE_PUBLIC_KEY="Ao7kIlRK7h2uvU6ZTD7W9XUkuvvQRehphG21MM4RDEg="

# SHA-1 leaf certificate для code signing. macOS TCC-разрешения (Запись экрана,
# Камера, Микрофон) привязаны к designated requirement приложения, включая этот
# certificate leaf. Если он изменится, разрешения у пользователей визуально могут
# остаться в настройках, но фактически перестанут совпадать с новой сборкой.
CODE_SIGN_CERT_SHA1="7A0F5956DFDBCFC326F1AF62302C34021A6C671C"

# Где публикуются релизы (GitHub). Поменяй OWNER на свой GitHub-логин.
# REPO можно оставить как есть (создай репозиторий с таким именем) или сменить.
SPARKLE_GITHUB_OWNER="webolruwork-coder"
SPARKLE_GITHUB_REPO="screenshotka"

# Итоговый URL фида обновлений. Шаблон менять не нужно — он всегда отдаёт
# appcast.xml, прикреплённый к ПОСЛЕДНЕМУ релизу на GitHub.
SPARKLE_FEED_URL="https://github.com/${SPARKLE_GITHUB_OWNER}/${SPARKLE_GITHUB_REPO}/releases/latest/download/appcast.xml"
